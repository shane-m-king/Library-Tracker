# Copy this file to .env and fill in real values.
# .env is gitignored so secrets never get committed.

# Port the Express server listens on
PORT=4000

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://library_app:your_password_here@localhost:5432/library_app

# Secret used to sign JWTs (generate with: openssl rand -hex 32)
JWT_SECRET=replace_with_a_long_random_string

# Origin of the frontend, allowed by CORS (the Vite dev server)
CLIENT_ORIGIN=http://localhost:5173

# Optional: Google Books API key. Search works without it but is heavily
# rate-limited. Get one at https://console.cloud.google.com (enable "Books API").
GOOGLE_BOOKS_API_KEY=
